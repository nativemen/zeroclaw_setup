# =============================================================================
# ZeroClaw Project .gitignore
# Optimized and organized for Docker/Rust/Shell project
# =============================================================================

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
build/
dist/
out/

# -----------------------------------------------------------------------------
# ZeroClaw Generated Data (runtime data, not source)
# -----------------------------------------------------------------------------
*.log                   # Log files

# -----------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL - never commit)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.backup*
*.pem
*.key
*.crt
*.secret
*.cred

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore

# Docker named volumes (data directories)
# These are managed by Docker, not version controlled
# Commented out as they're named volumes, not directories:
# docker/volumes/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes
Desktop.ini

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.ini
$RECYCLE.BIN/
Desktop.ini

# Linux
*.swp
*.swo
.Directory

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace
.history/

# JetBrains
.idea/
*.iml
*.ipr
*.iws
out/

# Vim
[._]*.s[a-v][a-z]
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session*
Session.vim
Sessionx.vim
.netrwhist

# Emacs
\#*\#
/.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.tmlanguage.cache
*.plist.user
*.sublime-workspace
*.sublime-project
sftp-config.json
Package Control.last-run
*.pyc

# -----------------------------------------------------------------------------
# Shell / Scripts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.env/

# -----------------------------------------------------------------------------
# Rust (if cargo is ever used)
# -----------------------------------------------------------------------------
# Cargo
target/
Cargo.lock

# Rust generated files
**/*.rs.bk
*.pdb

# Cargo mutants (mutation testing)
mutants.out*/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.backup*
*.orig
*.rej
*.patch
*.diff

# -----------------------------------------------------------------------------
# Test / Coverage
# -----------------------------------------------------------------------------
coverage/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.hypothesis/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.cache
*.lock
package-lock.json
yarn.lock
