# =============================================================================
# Tailscale Environment Configuration Template
# =============================================================================
# Copy this file to build/docker/.env.tailscale and fill in your values
# SECURITY: The actual .env file should have permissions 600 (chmod 600 .env)

# =============================================================================
# Tailscale VPN Configuration (REQUIRED for VPN mode)
# =============================================================================
# Tailscale authentication key
# Get it from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=

# Hostname in Tailscale network (for identification)
TAILSCALE_HOSTNAME=zeroclaw-wsl
