{
    "TCP": {
        "80": {
            "HTTP": true
        },
        "443": {
            "HTTPS": true
        }
    },
    "Web": {
        "${TS_CERT_DOMAIN}:80": {
            "Handlers": {
                "/": {
                    "Redirect": "https://${TS_CERT_DOMAIN}/"
                }
            }
        },
        "${TS_CERT_DOMAIN}:443": {
            "Handlers": {
                "/": {
                    "Proxy": "http://127.0.0.1:42617"
                }
            }
        }
    }
}