# ============================================================================
# Tailscale Environment Configuration Template
# =============================================================================
# Copy this file to build/docker/tailscale/env/.env.tailscale and fill in your values
# SECURITY: The actual .env file should have permissions 600 (chmod 600 .env)

# =============================================================================
# Tailscale VPN Configuration (REQUIRED for VPN mode)
# =============================================================================
# Tailscale authentication key
# Get it from: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Hostname in Tailscale network (for identification)
TS_HOSTNAME=zeroclaw

# =============================================================================
# Tailscale Container Configuration
# =============================================================================
# Authentication: if true, the container will not require re-authentication on restart
TS_AUTH_ONCE=true

# Directory to store Tailscale state (credentials, keys, etc.)
TS_STATE_DIR=/var/lib/tailscale

# Use userspace networking mode (false = kernel mode with /dev/net/tun)
# Kernel mode (false) is required for Docker sidecar network_mode
TS_USERSPACE=false

# Enable network stack integration (false = just VPN tunnel, no extra routing)
TS_NETSTACK=false

# Enable SSH via Tailscale
TS_SSH_ENABLED=true

# Extra arguments passed to tailscaled
TS_EXTRA_ARGS=--advertise-tags=tag:zeroclaw

TS_SERVE_CONFIG=/etc/tailscaled/serve-config.json