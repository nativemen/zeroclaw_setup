# =============================================================================
# ZeroClaw Environment Configuration Template
# =============================================================================
# Copy this file to build/docker/.env.zeroclaw and fill in your values
# SECURITY: The actual .env file should have permissions 600 (chmod 600 .env)

# =============================================================================
# REQUIRED: API Configuration
# =============================================================================
# Your LLM provider API key
# SECURITY: Keep this value empty and use environment variable
ZEROCLAW_API_KEY=

# =============================================================================
# Provider Settings
# =============================================================================
# LLM provider: deepseek, ollama, openai, openrouter, anthropic, google
ZEROCLAW_PROVIDER=deepseek

# Model name (depends on provider)
# deepseek: deepseek-chat, deepseek-coder, deepseek-reasoner
# ollama: llama3, mistral, codellama
# openai: gpt-4o, gpt-4o-mini, gpt-4-turbo
# openrouter: anthropic/claude-3.5-sonnet, google/gemini-pro-1.5, meta-llama/llama-3.1-70b-instruct
# anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-3-5-haiku-20241022
# google: gemini-2.0-flash-exp, gemini-1.5-pro, gemini-1.5-flash
ZEROCLAW_MODEL=deepseek-chat

# Temperature for responses (0.0 - 1.0, default: 0.7)
ZEROCLAW_TEMPERATURE=0.7

# =============================================================================
# Network Settings
# =============================================================================
# ZeroClaw service port on host (default: 42617)
HOST_PORT=42617

# Allow public network binding (WARNING: Only enable with Tailscale VPN)
# When false, ZeroClaw only binds to Tailscale interface
ZEROCLAW_ALLOW_PUBLIC_BIND=false

# =============================================================================
# Autonomy & Security Settings
# =============================================================================
# Autonomy level: readonly, supervised, full
# readonly: AI can only read files
# supervised: AI can read and execute safe commands
# full: AI can execute any allowed command
ZEROCLAW_AUTONOMY_LEVEL=readonly

# Maximum actions per hour (rate limiting for security)
ZEROCLAW_MAX_ACTIONS_PER_HOUR=100

# Maximum cost per day in cents (100 = $1.00)
ZEROCLAW_MAX_COST_PER_DAY_CENTS=1000

# Workspace-only mode: prevents access outside designated workspace
ZEROCLAW_WORKSPACE_ONLY=true

# =============================================================================
# Memory Configuration
# =============================================================================
# Memory backend: sqlite (local storage)
ZEROCLAW_MEMORY_BACKEND=sqlite

# Embedding provider: none (privacy-focused, no data sent to external services)
# Set to "none" to disable embeddings
ZEROCLAW_EMBEDDING_PROVIDER=none

# =============================================================================
# Runtime Configuration
# =============================================================================
# Runtime kind: native (recommended for security)
ZEROCLAW_RUNTIME_KIND=native

# =============================================================================
# Security & Privacy Settings
# =============================================================================
# Enable request rate limiting
ZEROCLAW_SECURITY_RATE_LIMIT_ENABLED=true

# Enable input sanitization (blocks suspicious patterns)
ZEROCLAW_SECURITY_SANITIZE_INPUTS=true

# Enable audit logging (records all actions for security review)
ZEROCLAW_SECURITY_AUDIT_LOGGING=true

# =============================================================================
# Identity Configuration
# =============================================================================
# Identity format: openclaw
ZEROCLAW_IDENTITY_FORMAT=openclaw
