# =============================================================================
# ZeroClaw Environment Configuration Template
# Copy this file to build/docker/.env.zeroclaw and fill in your values
# SECURITY: The actual .env file should have permissions 600 (chmod 600 .env)
# =============================================================================

# =============================================================================
# REQUIRED: API Configuration
# =============================================================================
# Your LLM provider API key
# SECURITY: Keep this value empty and use environment variable
ZEROCLAW_API_KEY=

# =============================================================================
# Provider API Keys
# =============================================================================
# DeepSeek API Key
# DEEPSEEK_API_KEY=

# OpenAI API Key
# OPENAI_API_KEY=

# Anthropic API Key
# ANTHROPIC_API_KEY=

# Google Gemini API Key
# GEMINI_API_KEY=

# OpenRouter API Key
# OPENROUTER_API_KEY=

# Moonshot API Key
# MOONSHOT_API_KEY=

# GLM API Key
# GLM_API_KEY=

# Minimax API Key
# MINIMAX_API_KEY=
# MINIMAX_OAUTH_TOKEN=

# =============================================================================
# Provider Settings
# =============================================================================
# LLM provider: deepseek, ollama, openai, openrouter, anthropic, google
ZEROCLAW_PROVIDER=deepseek

# Model name (depends on provider)
# deepseek: deepseek-chat, deepseek-coder, deepseek-reasoner
# ollama: llama3, mistral, codellama
# openai: gpt-4o, gpt-4o-mini, gpt-4-turbo
# openrouter: anthropic/claude-3.5-sonnet, google/gemini-pro-1.5, meta-llama/llama-3.1-70b-instruct
# anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-3-5-haiku-20241022
# google: gemini-2.0-flash-exp, gemini-1.5-pro, gemini-1.5-flash
ZEROCLAW_MODEL=deepseek-chat

# Temperature for responses (0.0 - 1.0, default: 0.7)
ZEROCLAW_TEMPERATURE=0.4

# =============================================================================
# Network Settings
# =============================================================================
# Default gateway host inside container
ZEROCLAW_GATEWAY_HOST=0.0.0.0

# Default gateway port inside container
ZEROCLAW_GATEWAY_PORT=42617

# Allow public bind inside Docker (required for container networking)
ZEROCLAW_ALLOW_PUBLIC_BIND=true

# =============================================================================
# Storage Settings
# =============================================================================
# Storage backend: sqlite (default), postgres
ZEROCLAW_STORAGE_PROVIDER=sqlite

# Database connection URL (for postgres)
# ZEROCLAW_STORAGE_DB_URL=postgres://user:pass@localhost/zeroclaw

# Connection timeout in seconds
ZEROCLAW_STORAGE_CONNECT_TIMEOUT_SECS=5

# =============================================================================
# Workspace Settings
# =============================================================================
# Workspace directory override
ZEROCLAW_WORKSPACE=/zeroclaw-data/workspace

# =============================================================================
# Web Search Settings
# =============================================================================
# Enable web search (default: true)
WEB_SEARCH_ENABLED=true

# Web search provider: duckduckgo (default), brave
# WEB_SEARCH_PROVIDER=duckduckgo

# Maximum search results (default: 5)
# WEB_SEARCH_MAX_RESULTS=5

# Search timeout in seconds (default: 15)
# WEB_SEARCH_TIMEOUT_SECS=15
